<!DOCTYPE html>
<html>

<head>
    <title><%= @title || 'Draft' %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1" name="viewport" />
    <%= yield :meta %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>
    <script src="https://use.fontawesome.com/releases/v5.15.4/js/all.js" data-mutate-approach="sync"></script>
    <%= javascript_importmap_tags %>
</head>

<% theme_pref = current_user&.theme || "system" %>
<body class="<%= controller.controller_name %> <%= controller.action_name %>" data-theme="<%= theme_pref %>">
    <script data-turbo-cache="false">
      (function() {
        var pref = document.body.getAttribute("data-theme");
        if (pref === "system") {
          var isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.body.setAttribute("data-theme", isDark ? "dark" : "light");
        }
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function(e) {
          if ("<%= theme_pref %>" === "system") {
            document.body.setAttribute("data-theme", e.matches ? "dark" : "light");
          }
        });
      })();
    </script>
    <% unless flash.empty? %>
      <script type="text/javascript" data-turbo-cache="false">
        toastr.options.preventDuplicates = true;
        toastr.options.closeMethod = 'fadeOut';

        <% flash.each do |f| %>
          <% type = f[0].to_s.gsub('alert', 'error').gsub('notice', 'info') %>
          toastr['<%= type %>']('<%= f[1] %>', {timeOut: 3});
        <% end %>
      </script>
    <% end %>

    <div class="page">
      <div class="header">
        <%= yield :header%>
      </div>

      <div class="container">
        <%= yield %>
      </div>
    </div>
</body>

</html>